# IndiaPix Metadata Automation System — Environment Configuration
# Copy this to .env and fill in your values

# ══════════════════════════════════════════════════════════
# AI Provider Configuration
# ══════════════════════════════════════════════════════════

# Choose the default AI provider: "claude" or "openai"
AI_PROVIDER=claude

# Anthropic (Claude) API Key — https://console.anthropic.com/
# Required if AI_PROVIDER is "claude"
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# OpenAI (GPT) API Key — https://platform.openai.com/api-keys
# Required if AI_PROVIDER is "openai"
OPENAI_API_KEY=

# Claude model override (optional)
# CLAUDE_MODEL=claude-sonnet-4-6

# ══════════════════════════════════════════════════════════
# Server Configuration
# ══════════════════════════════════════════════════════════

HOST=0.0.0.0
PORT=8000
UPLOAD_DIR=./temp_uploads

# Stale upload cleanup TTL (hours) — uploaded files older than this
# are automatically deleted by the background cleanup task.
# Default: 1 hour. Set to 0 to disable automatic cleanup.
UPLOAD_TTL_HOURS=1

# ══════════════════════════════════════════════════════════
# Scene Change Detection (Phase 2)
# ══════════════════════════════════════════════════════════

# Enable intelligent frame extraction at scene boundaries instead of
# fixed time intervals. When enabled, FFmpeg detects scene transitions
# and frames are extracted at those meaningful boundaries.
SCENE_DETECTION_ENABLED=true

# Scene change sensitivity (0.1 = very sensitive, 0.5 = less sensitive).
# Lower values detect more scene changes. Default 0.3 works for most content.
# SCENE_SENSITIVITY=0.3

# ══════════════════════════════════════════════════════════
# Logging Configuration
# ══════════════════════════════════════════════════════════

# Directory for log files (created automatically if missing)
LOG_DIR=./logs

# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Log format: "json" for structured JSON lines, "text" for human-readable
LOG_FORMAT=json

# Maximum size of a single log file before rotation (bytes) — default 10MB
LOG_MAX_BYTES=10485760

# Number of rotated log files to keep
LOG_BACKUP_COUNT=10